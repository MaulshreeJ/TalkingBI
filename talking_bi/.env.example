# Session Configuration
SESSION_EXPIRY_HOURS=24
MAX_FILE_SIZE_MB=10
CLEANUP_INTERVAL_MINUTES=10

# Multi-Provider LLM Configuration (Phase 0B Patch)
# Priority Order: Gemini → Groq → Mistral → OpenRouter

# Gemini Keys (Priority 1)
GEMINI_API_KEY_1=your_gemini_api_key_1_here
GEMINI_API_KEY_2=your_gemini_api_key_2_here

# Groq Keys (Priority 2 - Fast Fallback)
GROQ_API_KEY_1=your_groq_api_key_1_here
GROQ_API_KEY_2=your_groq_api_key_2_here

# Mistral Keys (Priority 3 - Secondary Fallback)
MISTRAL_API_KEY_1=your_mistral_api_key_1_here
MISTRAL_API_KEY_2=your_mistral_api_key_2_here

# OpenRouter Key (Priority 4 - Last Resort)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# API Configuration (if needed in future phases)
# DATABASE_URL=postgresql://user:password@localhost/dbname
# =========================================
# Talking BI - Canonical Environment Template
# =========================================
# Copy to .env and fill real values.
# Do not commit .env.

# Session and upload
SESSION_EXPIRY_HOURS=24
MAX_FILE_SIZE_MB=10
CLEANUP_INTERVAL_MINUTES=10

# Server runtime
HOST=127.0.0.1
PORT=8000

# Legacy single-key Gemini client support
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-pro

# Multi-provider keys (used by llm_manager)
GEMINI_API_KEY_1=your_gemini_api_key_1_here
GEMINI_API_KEY_2=your_gemini_api_key_2_here
GROQ_API_KEY_1=your_groq_api_key_1_here
GROQ_API_KEY_2=your_groq_api_key_2_here
MISTRAL_API_KEY_1=your_mistral_api_key_1_here
MISTRAL_API_KEY_2=your_mistral_api_key_2_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Test runner mode
TEST_MODE=FAST

# Optional future extension
# DATABASE_URL=postgresql://user:password@localhost/dbname

# Auth / JWT
SECRET_KEY=replace_with_a_long_random_secret

# Frontend URL used for OAuth callback handoff
FRONTEND_URL=http://127.0.0.1:5173

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/auth/oauth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://127.0.0.1:8000/auth/oauth/github/callback
